# ─────────────────────────────────────────────────────────────────────────────
# Myway — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it contains secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
PORT=48291

# ── Iframe Embedding ──────────────────────────────────────────────────────
# Comma-separated origins allowed to embed Myway in an iframe.
# When set, CORS headers + CSP frame-ancestors are added for these origins.
# MYWAY_ALLOWED_ORIGINS=https://approom.ai,https://staging.approom.ai

# ── API Authentication (Hosted mode only) ──────────────────────────────────
# Only set this for hosted/platform deployments. Self-hosted users should
# leave it commented out — setting it triggers hosted-mode behavior
# (multi-tenant auth, visitor detection) which breaks the self-hosted experience.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# MYWAY_API_TOKEN=your_api_token_here

# ── File System ──────────────────────────────────────────────────────────────
# Absolute path to the vault root exposed in the file browser.
# MYWAY_ROOT is intentionally unset in hosted mode — forces artifact-backed storage
# MYWAY_ROOT=/home/you/.myway/vault

# Virtual symlinks — expose specific files from outside MYWAY_ROOT.
# JSON array of { name, target }. Omit to disable.
# MYWAY_LINKS=[{"name":"notes.md","target":"/your/path/notes.md"}]

# ── Database ─────────────────────────────────────────────────────────────────
# Optional — default: ~/.myway/data/myway.db
# MYWAY_DB_PATH=/path/to/myway.db
# MYWAY_DATA_DIR=~/.myway/data

# ── AI Backend ────────────────────────────────────────────────────────────────
# Choose ONE mode. The setup wizard (npx @uchibeke/myway) handles this for you.
#
# MODE 1 — OpenClaw (default)
#   Uses OpenClaw as AI backbone. Requires OpenClaw running locally.
#
# OPENCLAW_BASE_URL=http://localhost:18789
# OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here

# ── Hosted mode — platform-provided AI backend ─────────────────────────────
# Default/fallback: Gemini (fast, OpenAI-compatible)
MYWAY_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
MYWAY_AI_TOKEN=your_gemini_or_openai_compatible_token
MYWAY_AI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=your_gemini_api_key

# Multi-provider model config (per-app model selection)
MYWAY_MODELS_CONFIG=~/.myway/models.json

# ── Additional provider keys (for future use) ──────────────────────────────
# OPENAI_API_KEY=sk-proj-...
# DEEPSEEK_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
#
# MODE 2 — BYOK (Bring Your Own Key)
#   Any OpenAI-compatible API. Set MYWAY_AI_BASE_URL and optionally a token.
#   Comment out the OPENCLAW_* vars above when using BYOK.
#   Myway is not affiliated with any of these providers.
#
#   Ollama (local, no token needed):
#     MYWAY_AI_BASE_URL=http://localhost:11434/v1
#     MYWAY_AI_MODEL=llama3
#
#   OpenAI:
#     MYWAY_AI_BASE_URL=https://api.openai.com/v1
#     MYWAY_AI_TOKEN=sk-...
#     MYWAY_AI_MODEL=gpt-4o
#
#   OpenRouter:
#     MYWAY_AI_BASE_URL=https://openrouter.ai/api/v1
#     MYWAY_AI_TOKEN=sk-or-v1-...
#
#   LiteLLM:
#     MYWAY_AI_BASE_URL=http://localhost:4000/v1
#     MYWAY_AI_TOKEN=your_litellm_key
#
#   Together AI:
#     MYWAY_AI_BASE_URL=https://api.together.xyz/v1
#     MYWAY_AI_TOKEN=your_together_key

# Webhook token for Myway → OpenClaw event bridge.
# Must match the token configured in your OpenClaw hooks endpoint.
# OPENCLAW_HOOK_TOKEN=your_hook_token_here

# Internal secret for encrypting OAuth tokens and OAuth CSRF protection.
# Required for Connections (Gmail, Calendar). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MYWAY_SECRET=your_64_char_hex_secret_here

# ── Branding (White-Label) ─────────────────────────────────────────────────────
# Override to white-label Myway. All optional — defaults to Myway branding.
# Can also be overridden per-iframe via URL params: ?brandPrimary=ff6600&brandBg=111111
# NEXT_PUBLIC_BRAND_NAME=MyApp
# NEXT_PUBLIC_BRAND_PRIMARY=2563eb
# NEXT_PUBLIC_BRAND_BG=09090b
# NEXT_PUBLIC_BRAND_FG=fafafa
# NEXT_PUBLIC_BRAND_THEME_COLOR=#000000

# ── Branding / Fork ─────────────────────────────────────────────────────────
# GitHub repo URL shown in settings. Override when forking.
# NEXT_PUBLIC_REPO_URL=https://github.com/uchibeke/myway

# ── User Preferences ──────────────────────────────────────────────────────────
# Display name shown in the UI (default: parsed from USER.md)
# MYWAY_USER_NAME=Your Name

# Timezone for email briefings and scheduling (default: system timezone)
MYWAY_TIMEZONE=America/Toronto

# Admin emails — comma-separated. Grants access to /apps/admin panel.
MYWAY_ADMIN_EMAILS=admin@example.com

# Override model pricing (name:inputPerMillion:outputPerMillion, comma-separated)
# MYWAY_MODEL_PRICING=my-model:0.50:2.00,another:1.00:5.00

# ── APort Guardrails (optional) ───────────────────────────────────────────────
# Myway works without APort. Install it for the Guardrails live feed.
# https://github.com/aporthq/aport-agent-guardrails
#
# Three evaluation modes (matching the OpenClaw plugin):
#   local  — Passport + policies evaluated on disk. No network. (default)
#   api    — Passport on disk, policies evaluated via APort API.
#   hosted — Set APORT_MODE=api + APORT_AGENT_ID. Passport in APort registry, everything via API.
#
# If OpenClaw is installed, mode is auto-detected from the plugin config.
#
# APORT_MODE=local
#
# Local mode paths — defaults to ~/.openclaw/aport/*. Only set if non-standard.
# OPENCLAW_DIR=~/.openclaw
# APORT_PASSPORT_FILE=~/.openclaw/aport/passport.json
# APORT_AUDIT_LOG=~/.openclaw/aport/audit.log
# APORT_DECISION_FILE=~/.openclaw/aport/decision.json
#
# API / Hosted mode — only needed if APORT_MODE=api and not using OpenClaw plugin.
# APORT_API_URL=https://api.aport.io
APORT_API_KEY=your_aport_api_key
APORT_BASE_URL=https://aport.io
APORT_ORG_ID=your_aport_org_id

# ── TTS (optional) ───────────────────────────────────────────────────────────
# Providers: inworld | lmnt | elevenlabs | moss
# Each provider reads a default voice from env (overridable per-request via voiceId).
INWORLD_API_KEY=your_inworld_api_key
INWORLD_VOICE_ID=your_inworld_voice_id
# LMNT_API_KEY=your_lmnt_key
# LMNT_VOICE_ID=your_lmnt_voice_id
# ELEVENLABS_API_KEY=your_elevenlabs_key
# ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id
# MOSS_TTS_API_KEY=your_moss_key
# MOSS_TTS_VOICE_ID=your_moss_voice_id

# ── Google Workspace OAuth (for Gmail + Calendar sync) ───────────────────────
# Create credentials at console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Telegram ──────────────────────────────────────────────────────────────────
# Optional — Myway works without Telegram.
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ── AppRoom Integration (Hosted Mode) ──────────────────────────────────────
# Required when connecting to AppRoom for billing, quota gating, and addons.
MYWAY_APPROOM_URL=https://approom.ai
MYWAY_INSTANCE_ID=prod
NEXT_PUBLIC_APPROOM_URL=https://approom.ai

# ── Subdomain Tenant Binding ──────────────────────────────────────────────
# When set, middleware verifies the request subdomain matches the session's
# assigned subdomain (e.g. user.myway.sh). Leave unset for single-user.
MYWAY_BASE_DOMAIN=myway.sh
NEXT_PUBLIC_APP_URL=https://myway.sh
MYWAY_MAX_FREE_SPEND=2.00
MYWAY_MAX_PAID_SPEND=8.00

# ── Partner Authentication (Platform Mode) ─────────────────────────────────
# Partners embed Myway in iframes and authenticate via HMAC-signed tokens.
# Each partner gets a shared secret. Myway verifies the token signature
# and extracts the user ID for tenant isolation.
#
# To add a partner:
# 1. Generate a shared secret (32+ hex chars):
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 2. Add env vars below (replace APPROOM with partner ID in UPPER_CASE):
# 3. Share the secret with the partner — they use it to sign tokens
# 4. Restart Myway
#
# Partner token format (created by partner backend):
#   payload = { userId, partnerId, timestamp, expiresAt, metadata? }
#   token = base64url(JSON.stringify(payload)) + '.' + hmac_sha256(base64url_part, secret)
#
# Example: AppRoom
MYWAY_PARTNER_APPROOM_SECRET=your_64_char_hex_secret_here
MYWAY_PARTNER_APPROOM_DOMAINS=approom.ai,staging.approom.ai
MYWAY_PARTNER_APPROOM_NAME=AppRoom
#
# Example: Another Partner
# MYWAY_PARTNER_ACME_SECRET=<64-char hex string>
# MYWAY_PARTNER_ACME_DOMAINS=acme.com

# ── System Health Thresholds ─────────────────────────────────────────────────
# Override defaults for health monitoring alerts.
# MYWAY_MEMORY_THRESHOLD_MB=512
# MYWAY_DISK_THRESHOLD_PERCENT=90
# MYWAY_AUTO_RECOVERY_ENABLED=true
# MYWAY_AUTO_RECOVERY_MAX_RESTARTS=5

# ─── Notifications ──────────────────────────────────────────────────────────
# Email via Resend (briefings, alerts)
RESEND_API_KEY=re_your_resend_api_key
MAIL_DOMAIN=mail.yourdomain.com

# SMS via Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
# MYWAY_FILE_WRITE_THRESHOLD=1000
