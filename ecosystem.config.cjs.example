/**
 * PM2 process config for Myway.
 *
 * All configuration is via .env.local — see .env.local.example for the full list.
 * Do NOT hardcode tokens, secrets, or personal paths in this file.
 *
 * @type {import('pm2').ProcessDescription}
 */
module.exports = {
  apps: [
    {
      name: 'myway',
      script: 'node_modules/.bin/next',
      args: `start --port ${process.env.PORT || 48291} --hostname 127.0.0.1`,
      cwd: __dirname,
      exec_mode: 'fork',
      autorestart: true,
      watch: false,
      max_memory_restart: '2G',
      restart_delay: 3000,
      max_restarts: 10,          // stop after 10 consecutive crashes (prevents infinite loop)
      min_uptime: '5s',          // must run 5s to count as "started" (resets restart counter)
      kill_timeout: 5000,        // wait 5s for old process to exit before SIGKILL
      env: {
        NODE_ENV: 'production',
        PORT: process.env.PORT || '48291',
      },
      out_file: './logs/out.log',
      error_file: './logs/error.log',
      log_date_format: 'YYYY-MM-DD HH:mm:ss',
      merge_logs: true,
    },
  ],
}
