/**
 * Private Apps — not shipped with the open-source release.
 *
 * This file is .gitignored. To add your own private apps to Myway:
 *  1. Copy this file to src/lib/apps-private.ts
 *  2. Add your app entries to the PRIVATE_APPS array
 *  3. If interactionType is 'tool', create a page at src/app/apps/<slug>/page.tsx
 *  4. Create a SKILL.md at ~/.openclaw/workspace/skills/<slug>/SKILL.md
 *
 * Private apps are loaded at startup and merged into the app registry.
 * They behave identically to public apps but are excluded from the
 * open-source distribution.
 */

