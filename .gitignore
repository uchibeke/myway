# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# logs
/logs

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# data
*.db
*.db-journal

# private / internal docs
/prds/
v0-enhancements.md
OPEN_SOURCE_PLAYBOOK.md

# private app data
hunter-sources.json
src/lib/hunter-sources.json

# private apps — registry, pages, API routes, and configs
src/lib/apps-private.ts
src/app/apps/hunter/
src/app/apps/influence/
src/app/api/influence/

# PM2 config (user-customizable — use ecosystem.config.cjs.example as template)
ecosystem.config.cjs

# npm tarballs
*.tgz
